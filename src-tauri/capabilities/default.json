{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "http:default",
      "allow": ["https://api.imgbb.com/*"]
    }
  ]
}
