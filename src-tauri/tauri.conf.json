{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Quiznac",
  "version": "0.1.2",
  "identifier": "com.quiznac.enac",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "nuxt dev",
    "beforeBuildCommand": "nuxt generate"
  },
  "app": {
    "windows": [
      {
        "title": "QUIZNAC",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "windows": {
      "allowDowngrades": true,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "minimumWebview2Version": null,
      "nsis": {
        "installMode": "currentUser"
      },
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false,
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      },

      "wix": {
        "language": "fr-FR",
        "template": "./main.wxs"
      }
    },
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
